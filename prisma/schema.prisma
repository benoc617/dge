generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum TurnMode {
  sequential
  simultaneous
}

enum PlanetType {
  FOOD
  ORE
  TOURISM
  PETROLEUM
  URBAN
  EDUCATION
  GOVERNMENT
  SUPPLY
  RESEARCH
  ANTI_POLLUTION
}

model UserAccount {
  id           String    @id @default(cuid())
  username     String    @unique
  fullName     String
  email        String    @unique
  passwordHash String
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  players Player[]
}

model Player {
  id            String       @id @default(cuid())
  name          String
  passwordHash  String?
  isAI          Boolean      @default(false)
  aiPersona     String?
  turnOrder     Int          @default(0)
  gameSessionId String?
  gameSession   GameSession? @relation(fields: [gameSessionId], references: [id])
  userId        String?
  user          UserAccount? @relation(fields: [userId], references: [id])
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  empire Empire?
  turns  TurnLog[]

  @@unique([name, gameSessionId])
}

model Empire {
  id       String @id @default(cuid())
  playerId String @unique
  player   Player @relation(fields: [playerId], references: [id])

  credits Int @default(10000)
  food    Int @default(800)
  ore     Int @default(400)
  fuel    Int @default(150)

  population  Int @default(25000)
  taxRate     Int @default(25)
  civilStatus Int @default(0)

  foodSellRate      Int @default(0)
  oreSellRate       Int @default(50)
  petroleumSellRate Int @default(50)

  netWorth    Int @default(0)
  turnsPlayed Int @default(0)
  turnsLeft   Int @default(100)

  isProtected     Boolean @default(true)
  protectionTurns Int     @default(20)
  tickProcessed   Boolean @default(false)
  /** Door-game (simultaneous) mode: economy tick ran but end_turn not yet issued for this full turn. */
  turnOpen                 Boolean @default(false)
  /** Door-game mode: full turns (tick → actions → end_turn) consumed this calendar round. */
  fullTurnsUsedThisRound   Int     @default(0)

  /** Queued messages shown on the defender's next turn situation report (ALERT lines). Stored as JSON array (MySQL). */
  pendingDefenderAlerts Json @default("[]")

  planets     Planet[]
  army        Army?
  supplyRates SupplyRates?
  research    Research?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Planet {
  id       String @id @default(cuid())
  empireId String
  empire   Empire @relation(fields: [empireId], references: [id], onDelete: Cascade)

  name                String
  sector              Int
  type                PlanetType
  population          Int     @default(0)
  longTermProduction  Int     @default(100)
  shortTermProduction Int     @default(100)
  defenses            Int     @default(0)
  isRadiated          Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Army {
  id       String @id @default(cuid())
  empireId String @unique
  empire   Empire @relation(fields: [empireId], references: [id], onDelete: Cascade)

  soldiers        Int @default(0)
  generals        Int @default(0)
  fighters        Int @default(0)
  defenseStations Int @default(0)
  lightCruisers   Int @default(0)
  heavyCruisers   Int @default(0)
  carriers        Int @default(0)
  covertAgents    Int @default(0)

  soldiersLevel      Int @default(0)
  fightersLevel      Int @default(0)
  stationsLevel      Int @default(0)
  lightCruisersLevel Int @default(0)
  heavyCruisersLevel Int @default(0)

  commandShipStrength Int @default(0)
  effectiveness       Int @default(100)
  covertPoints        Int @default(0)
}

model SupplyRates {
  id       String @id @default(cuid())
  empireId String @unique
  empire   Empire @relation(fields: [empireId], references: [id], onDelete: Cascade)

  rateSoldier      Int @default(40)
  rateFighter      Int @default(20)
  rateStation      Int @default(10)
  rateHeavyCruiser Int @default(0)
  rateCarrier      Int @default(0)
  rateGeneral      Int @default(10)
  rateCovert       Int @default(10)
  rateCredits      Int @default(10)
}

model Market {
  id          String @id @default(cuid())
  foodSupply  Int    @default(500000)
  foodRatio   Float  @default(1.0)
  oreSupply   Int    @default(500000)
  oreRatio    Float  @default(1.0)
  petroSupply Int    @default(500000)
  petroRatio  Float  @default(1.0)

  coordinatorPool Int @default(0)
  lotteryPool     Int @default(0)
}

enum TreatyType {
  NEUTRALITY
  FREE_TRADE
  MINOR_ALLIANCE
  TOTAL_DEFENSE
  ARMED_DEFENSE_PACT
  CRUISER_PROTECTION
}

enum TreatyStatus {
  PENDING
  ACTIVE
  EXPIRED
  BROKEN
}

model Treaty {
  id             String       @id @default(cuid())
  fromEmpireId   String
  toEmpireId     String
  type           TreatyType
  status         TreatyStatus @default(PENDING)
  turnsRemaining Int          @default(20)
  isBinding      Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Coalition {
  id        String   @id @default(cuid())
  name      String   @unique
  leaderId  String
  memberIds Json @default("[]")
  maxMembers Int     @default(5)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ConvoyType {
  TRADE
  MILITARY
  COLONIZATION
}

model Convoy {
  id             String     @id @default(cuid())
  fromEmpireId   String
  toEmpireId     String?
  type           ConvoyType
  contents       Json       @default("{}")
  turnsRemaining Int        @default(5)
  sectorFrom     Int
  sectorTo       Int
  createdAt      DateTime   @default(now())
}

model Message {
  id           String   @id @default(cuid())
  fromPlayerId String
  toPlayerId   String
  subject      String
  body         String
  isRead       Boolean  @default(false)
  createdAt    DateTime @default(now())
}

model Research {
  id                String   @id @default(cuid())
  empireId          String   @unique
  empire            Empire   @relation(fields: [empireId], references: [id], onDelete: Cascade)
  accumulatedPoints Int      @default(0)
  unlockedTechIds   Json @default("[]")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Loan {
  id             String   @id @default(cuid())
  empireId       String
  principal      Int
  balance        Int
  interestRate   Int      @default(50)
  turnsRemaining Int      @default(20)
  createdAt      DateTime @default(now())
}

model Bond {
  id             String   @id @default(cuid())
  empireId       String
  amount         Int
  interestRate   Int      @default(10)
  turnsRemaining Int      @default(30)
  createdAt      DateTime @default(now())
}

model TurnLog {
  id        String   @id @default(cuid())
  playerId  String
  player    Player   @relation(fields: [playerId], references: [id])
  action    String
  details   Json?
  createdAt DateTime @default(now())
}

model GameEvent {
  id            String        @id @default(cuid())
  gameSessionId String?
  gameSession   GameSession?  @relation(fields: [gameSessionId], references: [id])
  type          String
  message       String        @db.Text
  details       Json?
  createdAt     DateTime      @default(now())
}

model HighScore {
  id         String   @id @default(cuid())
  playerName String
  netWorth   Int
  population Int
  planets    Int
  turnsPlayed Int
  rank       Int
  totalPlayers Int
  finishedAt DateTime @default(now())
}

/** Singleton row `id = "admin"`. When present, admin login uses bcrypt `passwordHash`; otherwise `INITIAL_ADMIN_PASSWORD` env (default srxpass). Username always `ADMIN_USERNAME` env. */
model AdminSettings {
  id           String   @id
  passwordHash String
  updatedAt    DateTime @updatedAt
}

/** Singleton row `id = "default"`. Optional Gemini + door-game AI concurrency overrides; `DATABASE_URL` stays in environment only. */
model SystemSettings {
  id           String   @id @default("default")
  geminiApiKey String?
  geminiModel  String?  @default("gemini-2.5-flash")
  /** Max AIs per parallel `getAIMoveDecision` wave (door-game). */
  doorAiDecideBatchSize   Int @default(4)
  /** Global cap on concurrent Gemini `generateContent` calls. */
  geminiMaxConcurrent     Int @default(4)
  /** Global cap on concurrent Optimal-persona MCTS runs in `getAIMove`. */
  doorAiMaxConcurrentMcts Int @default(1)
  /** Wall-clock ms per `getAIMoveDecision` race (door-game AI). */
  doorAiMoveTimeoutMs     Int @default(60000)
  updatedAt    DateTime @updatedAt
}

model GameSession {
  id               String   @id @default(cuid())
  galaxyName       String?  @unique
  createdBy        String?
  isPublic         Boolean  @default(true)
  inviteCode       String?  @unique
  maxPlayers       Int      @default(50)
  currentTurnIndex    Int      @default(0)
  currentTurnPlayerId String?
  /** Null when lobby has not started (no human yet); timer not running. */
  turnStartedAt       DateTime?
  turnTimeoutSecs     Int      @default(86400)
  /** Admin-staged galaxy: no turn timer / no actions until first human joins. */
  waitingForHuman     Boolean  @default(false)

  playerNames  Json @default("[]")
  totalTurns   Int      @default(100)
  status       String   @default("active")
  winnerId     String?
  winnerName   String?
  finalScores  Json?
  log          Json     @default("[]")
  startedAt    DateTime @default(now())
  finishedAt   DateTime?

  /** Identifies which game engine definition runs this session (e.g. "srx"). */
  gameType          String     @default("srx")
  turnMode          TurnMode   @default(sequential)
  /** Calendar day counter (door-game / simultaneous mode). */
  dayNumber         Int        @default(1)
  actionsPerDay     Int        @default(5)
  /** When the current round (day) started; round timer = roundStartedAt + turnTimeoutSecs. */
  roundStartedAt    DateTime?

  players    Player[]
  gameEvents GameEvent[]
}

/** One row per GameSession — used for MySQL FOR UPDATE NOWAIT advisory-lock equivalent. */
model SessionLock {
  sessionId String   @id
  lockedAt  DateTime @default(now())
}

/**
 * Door-game (simultaneous) AI turn job queue.
 * Web tier inserts pending rows; the ai-worker process claims and executes them.
 * Uses SELECT … FOR UPDATE SKIP LOCKED so multiple workers never collide.
 */
model AiTurnJob {
  id          String    @id @default(cuid())
  sessionId   String
  playerId    String
  /** pending | claimed | done | failed */
  status      String    @default("pending")
  /** Unique ID of the worker instance that claimed this job. */
  claimedBy   String?
  claimedAt   DateTime?
  completedAt DateTime?
  /** { success, ms } on done; { error } on failed. */
  result      Json?
  createdAt   DateTime  @default(now())

  @@index([status, createdAt])
  @@index([sessionId, status])
  @@index([playerId, status])
}
