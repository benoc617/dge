{
  "name": "solar-realms-extreme",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "node scripts/fix-tsc-bin.js && prisma generate",
    "typecheck": "node ./node_modules/typescript/lib/tsc.js --noEmit",
    "dev": "next dev",
    "dev:webpack": "next dev --webpack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "sim": "npx tsx scripts/simulate.ts",
    "sim:quick": "npx tsx scripts/simulate.ts --turns 30 --players 3 --seed 42 --reset",
    "sim:full": "npx tsx scripts/simulate.ts --turns 100 --players 5 --seed 42 --reset --verbosity 2",
    "sim:stress": "npx tsx scripts/simulate.ts --repeat 10 --turns 100 --players 5 --seed 1 --reset",
    "sim:balance": "npx tsx scripts/simulate.ts --reset --repeat 25 --turns 100 --players 8 --seed 1 --verbosity 0",
    "sim:session:seq": "npx tsx scripts/simulate.ts --session sequential --turns 30 --players 3 --seed 42 --verbosity 1",
    "sim:session:sim": "npx tsx scripts/simulate.ts --session simultaneous --apd 1 --turns 30 --players 3 --seed 42 --verbosity 1",
    "sim:csv": "npx tsx scripts/simulate.ts --turns 100 --players 5 --seed 42 --reset --csv sim_output.csv",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:e2e": "PORT=3005 TEST_BASE_URL=http://127.0.0.1:3005 start-server-and-test \"npm run dev\" http://127.0.0.1:3005 \"vitest run --config vitest.e2e.config.ts tests/e2e\"",
    "test:e2e:only": "vitest run --config vitest.e2e.config.ts tests/e2e",
    "test:all": "npm run test:unit && npm run test:e2e",
    "test:coverage": "vitest run --coverage",
    "docker:test": "docker compose exec app npm test",
    "docker:test:e2e": "docker compose exec app env TEST_BASE_URL=http://127.0.0.1:3000 npm run test:e2e:only",
    "docker:test:all": "docker compose exec app sh -c 'npm test && TEST_BASE_URL=http://127.0.0.1:3000 npm run test:e2e:only'",
    "docker:lint": "docker compose exec app npm run lint",
    "docker:typecheck": "docker compose exec app npm run typecheck",
    "docker:build": "docker compose exec app npm run build",
    "docker:up": "docker compose up --build",
    "docker:dev:redeploy": "bash scripts/docker-dev-redeploy.sh",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f app",
    "docker:reset-node-modules": "bash scripts/docker-reset-node-modules-volume.sh",
    "deploy": "bash scripts/deploy-docker-dev.sh",
    "seed:system-settings": "npx tsx scripts/seed-system-settings.ts",
    "repair:door-session": "npx tsx scripts/repair-door-game-session.ts"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@prisma/adapter-mariadb": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@tailwindcss/postcss": "^4",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.0",
    "ioredis": "^5.6.1",
    "mariadb": "^3.4.0",
    "next": "16.2.2",
    "prisma": "^7.6.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwindcss": "^4"
  },
  "overrides": {
    "picomatch": "^4.0.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "start-server-and-test": "^2.1.5",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.2"
  }
}
